<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark application theme. -->
    <style name="Theme.Speech" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="color">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="cardViewStyle">@style/CardView</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.v14.Material</item>
        <item name="android:windowBackground">@color/background_primary</item>
    </style>

    <style name="Theme.Settings" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="color">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/background_secondary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="cardViewStyle">@style/CardView</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.v14.Material</item>
    </style>
</resources>
